# Claude / Anthropic API Key
# Get it at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# TikTok Access Token
# Obtained after the OAuth flow in the TikTok Developer Portal
# Required scopes: video.publish, video.upload
TIKTOK_ACCESS_TOKEN=act....

# Optional: TikTok Client Key (for OAuth refresh)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Optional: Pexels API Key (for background videos)
# Get it at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: ElevenLabs API Key (for premium English voices)
# Get it at: https://elevenlabs.io/
# Without this, Edge TTS is used as fallback (free, slightly lower quality)
ELEVENLABS_API_KEY=

# Optional: Override ElevenLabs voice IDs
# Default Narrator: Adam (pNInz6obpgDQGcFmaJgB) — calm, authoritative
# Default Creator:  Sarah (EXAVITQu4vr4xnSDxMaL) — energetic, young
ELEVENLABS_VOICE_NARRATOR=
ELEVENLABS_VOICE_CREATOR=

# Optional: Override Claude model (default: claude-sonnet-4-5)
ANTHROPIC_MODEL=
